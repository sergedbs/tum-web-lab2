---
import { Image } from 'astro:assets';
import site from '../data/site.json';
import hero from '../data/hero.json';
import hours from '../data/hours.json';
import '../styles/reset.css';
import '../styles/style.css';
import logoUrl from '../assets/moments-logo.jpg';
import coffeeUrl from '../assets/coffee.png';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.name} - ${hero.title}`,
  description = site.description,
} = Astro.props;

const { siteUrl, phone, phoneDisplay, instagram, facebook, year, mascotMessage, mapsEmbed } = site;

// Pass close hours to main.js via data attributes (CMS-editable)
const cafeWeekday = hours.cafe[0];
const cafeWeekend = hours.cafe[1];
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <!-- Open Graph / social-sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}images/background.jpg`} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
    <link rel="icon" type="image/jpeg" href={logoUrl.src} />
    <!-- DNS prefetch & preconnect for external resources -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
    <!-- Web fonts: Playfair Display (headings) + Lato (body) -->
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;1,700&family=Lato:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "CafeOrCoffeeShop",
      name: site.name,
      description: site.description,
      url: siteUrl,
      telephone: phone,
      address: { "@type": "PostalAddress", streetAddress: "E581", addressCountry: "MD" },
      openingHoursSpecification: [
        { "@type": "OpeningHoursSpecification", dayOfWeek: ["Monday","Tuesday","Wednesday","Thursday"], opens: "07:00", closes: `${cafeWeekday.closeHour}:00` },
        { "@type": "OpeningHoursSpecification", dayOfWeek: ["Friday","Saturday","Sunday"],              opens: "07:00", closes: `${cafeWeekend.closeHour}:00` }
      ],
      sameAs: [instagram, facebook]
    })} />
  </head>
  <body>
    <!-- Skip to main content (accessibility) -->
    <a href="#about" class="visually-hidden-focusable skip-link">Sari la conținut</a>

    <!-- Mobile scroll progress bar -->
    <div class="scroll-progress" id="scrollProgress"></div>

    <slot />

    <!-- Back to top (desktop only) -->
    <button class="back-to-top" id="backToTop" aria-label="Înapoi sus">
      <i class="fa-solid fa-chevron-up"></i>
    </button>

    <!-- Mascot: Cico the coffee cup (Clippy-style) -->
    <div class="mascot" id="mascot" role="complementary" aria-label="Mascota Moments Café">
      <div class="mascot__bubble" set:html={mascotMessage.replace('—', '—<br />')}></div>
      <div class="mascot__body">
        <Image
          src={coffeeUrl}
          alt=""
          class="mascot__svg"
          aria-hidden="true"
          width={80}
          loading="eager"
        />
      </div>
    </div>

    <!-- Mobile-only sticky call bar -->
    <div
      class="mobile-call-bar d-md-none"
      id="mobileCallBar"
      data-close-weekday={cafeWeekday.closeHour}
      data-close-weekend={cafeWeekend.closeHour}
    >
      <div class="mobile-call-bar__status" id="callBarStatus"></div>
      <a href={`tel:${phone}`} class="mobile-call-bar__btn">
        <i class="fa-solid fa-phone"></i> {phoneDisplay}
      </a>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      crossorigin="anonymous"></script>
    <script>
      import '../js/main.js';
    </script>
  </body>
</html>
