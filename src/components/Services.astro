---
import content from '../data/content.json';
const { services } = content;
---

<section class="services" id="services">
  <div class="container">
    <h2 class="section-title">{services.title}</h2>
    <div class="row g-4 mt-2">
      {services.items.map((item, i) => (
        <div class="col-md-4">
          <div
            class="service-card h-100 animate-on-scroll"
            style={i > 0 ? `transition-delay:${i * 0.1}s` : undefined}
          >
            <div class="service-icon"><i class={item.icon}></i></div>
            <h3 class="service-title">{item.title}</h3>
            <p class="service-description">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
  <div class="container">
    <h2 class="section-title">Ce Oferim</h2>
    <div class="row g-4 mt-2">
      <!-- Service Card 1: Café -->
      <div class="col-md-4">
        <div class="service-card h-100 animate-on-scroll">
          <div class="service-icon"><i class="fa-solid fa-mug-hot"></i></div>
          <h3 class="service-title">Cafea Premium</h3>
          <p class="service-description">
            Trezește-te cu aroma unei cafele autentice! Cappuccino, espresso, latte pregătite de
            barista profesioniști. Cafea la drum nu înseamnă compromis de calitate.
          </p>
        </div>
      </div>

      <!-- Service Card 2: Artisanal Food -->
      <div class="col-md-4">
        <div class="service-card h-100 animate-on-scroll" style="transition-delay:0.1s">
          <div class="service-icon"><i class="fa-solid fa-utensils"></i></div>
          <h3 class="service-title">Mâncare Proaspătă</h3>
          <p class="service-description">
            Uită de fast-food! Sandvișuri artizanale, salate fresh, feluri calde și deserturi
            preparate zilnic. Masa ta merită ingrediente de calitate, chiar și în drum.
          </p>
        </div>
      </div>

      <!-- Service Card 3: Market -->
      <div class="col-md-4">
        <div class="service-card h-100 animate-on-scroll" style="transition-delay:0.2s">
          <div class="service-icon"><i class="fa-solid fa-cart-shopping"></i></div>
          <h3 class="service-title">Market Complet</h3>
          <p class="service-description">
            Ai uitat ceva acasă? Nu-i problemă! Snacks, băuturi răcoritoare, produse de igienă și
            provizii pentru drum - totul într-un singur loc, fără timp pierdut.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
