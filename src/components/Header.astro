---
import logoUrl from '../assets/moments-logo.jpg';
import site from '../data/site.json';
import content from '../data/content.json';
---

<header class="header">
  <nav class="navbar navbar-expand-md navbar-dark container py-2">
    <h1 class="logo navbar-brand mb-0">
      <a href="#">
        <img
          src={logoUrl.src}
          alt={`${site.name} Logo`}
          style="height: 60px; width: 60px; border-radius: 50%; object-fit: cover;"
        />
      </a>
    </h1>
    <button
      class="navbar-toggler border-0"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#mainNav"
      aria-controls="mainNav"
      aria-expanded="false"
      aria-label="Deschide meniul"
    >
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="mainNav">
      <nav class="navbar-nav ms-auto">
        {content.nav.map((link) => (
          <a href={link.href} class="nav-link">
            <i class={`${link.icon} me-1`}></i>{link.label}
          </a>
        ))}
      </nav>
    </div>
  </nav>
</header>
    <button
      class="navbar-toggler border-0"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#mainNav"
      aria-controls="mainNav"
      aria-expanded="false"
      aria-label="Deschide meniul"
    >
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="mainNav">
      <nav class="navbar-nav ms-auto">
        <a href="#about" class="nav-link"
          ><i class="fa-solid fa-circle-info me-1"></i>Despre Noi</a
        >
        <a href="#services" class="nav-link"
          ><i class="fa-solid fa-mug-hot me-1"></i>Servicii</a
        >
        <a href="#hours" class="nav-link"
          ><i class="fa-solid fa-clock me-1"></i>Program</a
        >
        <a href="#contact" class="nav-link"
          ><i class="fa-solid fa-phone me-1"></i>Contact</a
        >
      </nav>
    </div>
  </nav>
</header>
