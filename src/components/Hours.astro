---
import hours from '../data/hours.json';
import site from '../data/site.json';
---

<section class="hours" id="hours">
  <div class="container">
    <h2 class="section-title">{hours.title}</h2>
    <div class="row g-4 mt-2">
      <div class="col-md-6">
        <div class="hours-box h-100 animate-on-scroll">
          <h3 class="hours-subtitle"><i class="fa-solid fa-mug-hot"></i> Cafenea</h3>
          {hours.cafe.map((row) => (
            <p class="hours-time">{row.days}: {row.time}</p>
          ))}
        </div>
      </div>

      <div class="col-md-6">
        <div class="hours-box h-100 animate-on-scroll" style="transition-delay:0.1s">
          <h3 class="hours-subtitle"><i class="fa-solid fa-cart-shopping"></i> Market</h3>
          {hours.market.map((row) => (
            <p class="hours-time">{row.days}: {row.time}</p>
          ))}
        </div>
      </div>

      <div class="col-12">
        <div class="location-box">
          <div class="row g-4 align-items-center">
            <div class="col-md-6 location-info">
              <h3 class="hours-subtitle">
                <i class="fa-solid fa-location-dot"></i> {hours.location.title}
              </h3>
              <p class="location-text">
                <strong>{hours.location.addressStrong}</strong><br />
                {hours.location.addressDetail}
              </p>
              <a href={`tel:${site.phone}`} class="cta-button secondary">
                Sună Acum: {site.phoneDisplay}
              </a>
            </div>
            <div class="col-md-6 map-container">
              <div class="ratio ratio-16x9">
                <iframe
                  src={site.mapsEmbed}
                  title="Moments Café & Market pe Google Maps"
                  style="border:0; border-radius: 8px;"
                  allowfullscreen=""
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"></iframe>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
