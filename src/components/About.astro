---
import about from '../data/about.json';
---

<section class="about" id="about">
  <div class="container">
    <h2 class="section-title">{about.title}</h2>
    <div class="about-content">
      {about.paragraphs.map((p) => (
        <p class="about-text">
          <strong>{p.label}:</strong> {p.text}
        </p>
      ))}
    </div>
  </div>
</section>
